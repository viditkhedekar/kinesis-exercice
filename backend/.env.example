# Copy to .env for local (non-docker) runs. Docker Compose sets these directly.
KINESIS_DATABASE_URL=postgresql+psycopg2://kinesis:kinesis@localhost:5432/kinesis
KINESIS_REDIS_URL=redis://localhost:6379/0
KINESIS_STORAGE_DIR=/data/kinesis

# --- Pose estimation performance (tune to trade speed vs accuracy) ---
# Model complexity: 0=lite (fastest), 1=full (default), 2=heavy (most accurate).
# Benchmark with `python -m scripts.benchmark_pose <clip>` before lowering.
KINESIS_POSE_MODEL_COMPLEXITY=1
KINESIS_POSE_TARGET_FPS=10        # temporal downsample target (~8-10 recommended)
KINESIS_POSE_MAX_DIM=640          # downscale longest side before inference (<=720p)
