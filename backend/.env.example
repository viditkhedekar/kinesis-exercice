# Copy to .env for local (non-docker) runs. Docker Compose sets these directly.
KINESIS_DATABASE_URL=postgresql+psycopg2://kinesis:kinesis@localhost:5432/kinesis
KINESIS_REDIS_URL=redis://localhost:6379/0
KINESIS_STORAGE_DIR=/data/kinesis

# --- Pose estimation performance (tune to trade speed vs accuracy) ---
# Model complexity: 0=lite (default, fastest), 1=full, 2=heavy (most accurate).
# Compare on your own clips with `python -m scripts.benchmark_pose <clip>`.
KINESIS_POSE_MODEL_COMPLEXITY=0
KINESIS_POSE_TARGET_FPS=5         # temporal downsample target
KINESIS_POSE_MAX_DIM=640          # downscale longest side before inference (~640x360)
KINESIS_POSE_DECODER=ffmpeg       # "ffmpeg" (fast, default) or "cv2" (force OpenCV)
KINESIS_POSE_REUSE_MODEL=true     # reuse one landmarker per worker thread across requests
KINESIS_POSE_RUNNING_MODE=video   # "video" (tracking) or "image" (detect per frame)
KINESIS_POSE_NUM_THREADS=0        # CPU inference thread hint (0=default; honoured by MoveNet)
KINESIS_POSE_BACKEND=mediapipe    # "mediapipe" (33 landmarks) or "movenet" (17 kpts, faster)
